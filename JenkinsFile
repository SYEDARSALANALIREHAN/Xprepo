pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                script {
                    sh '''
                        ls
                        npm install
                        echo "Turning analytics off"
                        ng build --prod
                        ls dist
                        cd dist && ls
                        cd dist/angular-tour-of-heroes/browser && ls
                    '''
                }
            }
        }

        stage('S3 Upload') {
            steps {
                withAWS(region: 'us-east-1', credentials: '8C94fa09-4954-4498-aac9-838d930a9170') {
                    sh '''
                        ls -la
                        aws s3 cp dist/angular-tour-of-heroes/browser/ s3://xprepo-bucket/ --recursive
                    '''
                }
            }
        }
    }
}
